# Hedda Telegram Bot - 配置模板
# 安装时会自动生成 .env 文件

# === 必需配置 ===

# Telegram Bot Token (从 @BotFather 获取)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# 允许的用户 ID (逗号分隔，运行 /id 命令获取你的 ID)
TELEGRAM_ALLOWED_USERS=123456789,987654321

# === 可选配置 ===

# OpenAI API Key (用于语音转文字功能)
# 如果不需要语音功能可以留空
OPENAI_API_KEY=

# Claude 工作目录 (默认是用户主目录)
CLAUDE_WORKING_DIR=$HOME

# 记忆文件路径 (可选，如果设置则会在每次新会话时自动加载)
# 示例：MEMORY_FILE_PATH=$HOME/clawd/piggyx/MEMORY.md
# 或使用项目内的：MEMORY_FILE_PATH=./memory/MEMORY.md
MEMORY_FILE_PATH=

# 日志文件目录 (默认是项目根目录的 logs 文件夹)
LOG_DIR=

# === 速率限制配置 ===

# 启用速率限制
RATE_LIMIT_ENABLED=true

# 时间窗口内允许的请求数
RATE_LIMIT_REQUESTS=20

# 时间窗口（秒）
RATE_LIMIT_WINDOW=60

# === 思考模式配置 ===

# 默认思考 tokens 数量
DEFAULT_THINKING_TOKENS=10000

# 触发思考的关键词（逗号分隔）
THINKING_KEYWORDS=think,pensa,ragiona,思考

# 触发深度思考的关键词
THINKING_DEEP_KEYWORDS=ultrathink,think hard,深度思考

# === 高级配置 ===

# 媒体组超时（毫秒）
MEDIA_GROUP_TIMEOUT=1000

# 流式更新节流（毫秒）
STREAMING_THROTTLE_MS=500

# 查询超时（毫秒，3分钟）
QUERY_TIMEOUT_MS=180000
